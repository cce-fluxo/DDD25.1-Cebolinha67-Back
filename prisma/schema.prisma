// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model consulta {
  id Int @id @default(autoincrement())
  id_paciente Int
  id_dentista Int
  id_convenio Int
  id_endereco Int
}

enum tipo_pagamento {
  Particular
  Convenio
}

model detalhe_da_consulta {
  id_consulta Int 
  DH DateTime
  valor Int
  tipo_pagamento tipo_pagamento @unique
  status String
  tipo_consulta String
  motivo String
}

model dentista {
  id_dentista Int @id @default(autoincrement())
  Senha_dentista String
  Formacao String
  Instituto String
  DataInicio DateTime
  DataTermino DateTime
  Especializacao String
}

model endereco {
  id_endereco Int @id @default(autoincrement())
  id_dentista Int 
  dataCriacaoEndereco DateTime
  Logradouro String
  Cidade String
  Estado String
  Bairro String
  complemento String
  CEP String
}
