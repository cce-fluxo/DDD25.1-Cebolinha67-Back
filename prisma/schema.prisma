// SEÇÃO DE PESSOAS (DENTISTA, PACIENTE, USUÁRIO)

model Usuario{
  id Int @id @default(autoincrement())
  no_usuario String
  email_usuario String @unique
  cpf String @unique
  nu_celular String @unique
  genero Genero
  data_nascimento DateTime
  token_esqueci_senha String

  // RELACIONAMENTOS
  notificacao_usuario NotificacaoUsuario[]
  imagem_usuario ImagemUsuario?
  
  paciente Paciente?
  dentista Dentista? 

  } 

enum Genero {
  Masculino
  Feminino
  Outros
  NaoInformado
}

model Dentista{
  id Int @id @default(autoincrement())
  senha_dentista String
  formacao String
  instituto String
  datainicio DateTime
  datatermino DateTime
  especializacao String

  // RELACIONAMENTOS
  id_usuario Int @unique
  usuario Usuario @relation(fields:[id_usuario], references: [id])
  postagem Postagem[]
  endereco Endereco?
  consultas Consulta[]
}

model Paciente{
  id Int @id @default(autoincrement())
  senha_paciente String
  rg String @unique

  // RELACIONAMENTOS
  id_usuario Int @unique
  usuario Usuario @relation(fields:[id_usuario], references: [id])
  convenios Convenio[]
  consultas Consulta[]
  postagem_paciente PostagemPaciente[]
}

// NOTIFICAÇÕES 

model Notificacao{
  id Int @id @default(autoincrement())
  ds_mensagem String
  lido Boolean
  titulo String
  simbolo String

  // RELACIONAMENTOS
  notificacao_usuario NotificacaoUsuario?
}

model NotificacaoUsuario{
  id Int @id @default(autoincrement())

  // RELACIONAMENTOS
  id_notificacao Int @unique
  notificacao Notificacao @relation(fields: [id_notificacao], references: [id])
  id_usuario Int 
  usuario Usuario @relation(fields: [id_usuario], references: [id])
  id_consulta Int? 
  consulta Consulta? @relation(fields: [id_consulta], references: [id])

  @@unique([id_usuario, id_notificacao])
}

// IMAGENS

model Imagem{
  id Int @id @default(autoincrement())
  url String @unique
  nome String

  // RELACIONAMENTOS
  imagem_usuario ImagemUsuario[]
  imagem_postagem ImagemPostagem[]
}

model ImagemUsuario{
  id Int @id @default(autoincrement())

  // RELACIONAMENTOS
  id_imagem Int 
  imagem Imagem @relation(fields: [id_imagem], references: [id])
  id_usuario Int @unique
  usuario Usuario @relation(fields: [id_usuario], references: [id])

  @@unique([id_imagem, id_usuario])
}

model ImagemPostagem{
  id Int @id @default(autoincrement())

  // RELACIONAMENTOS
  id_imagem Int 
  imagem Imagem @relation(fields: [id_imagem], references: [id])
  id_postagem Int 
  postagem Postagem @relation(fields: [id_postagem], references: [id])

  @@unique([id_imagem, id_postagem])
}

// ENDERECO

model Endereco{
  id Int @id @default(autoincrement())
  data_criacao_endereco DateTime @default(now())
  logradouro String
  cidade String
  estado String
  bairro String
  complemento String
  cep String

  // RELACIONAMENTOS
  id_dentista Int @unique
  dentista Dentista @relation(fields: [id_dentista], references: [id])
  consultas Consulta[]
}

// CONSULTA

model Consulta {
  id Int @id @default(autoincrement())

  // RELACIONAMENTOS
  id_paciente Int 
  paciente Paciente @relation(fields: [id_paciente], references: [id])
  id_dentista Int @unique
  dentista Dentista @relation(fields: [id_dentista], references: [id])
  id_convenio Int @unique
  convenio Convenio @relation(fields: [id_convenio], references: [id])
  id_endereco Int @unique
  endereco Endereco @relation(fields: [id_endereco], references: [id])
  detalhe_da_consulta DetalheDaConsulta?
  documentos Documento[]
  notificacao_usuario NotificacaoUsuario[]
}

model DetalheDaConsulta {
  id Int @id @default(autoincrement())
  DH DateTime 
  valor Int
  tipo_pagamento TipoPagamento
  status String
  tipo_consulta String
  motivo String

  // RELACIONAMENTOS
  id_consulta Int @unique
  consulta Consulta @relation(fields: [id_consulta], references: [id])
}

// tipo_pagamento é atributo (enumerado) da entidade detalhe_da_consulta
enum TipoPagamento {
  particular
  convenio
}

// POSTAGEM

model Postagem{
  id Int @id @default(autoincrement())
  titulo String @db.VarChar(150)
  mensagem String @db.Text
  tipo TipoPostagem 
  data_criacao DateTime @default(now())
  
  // RELACIONAMENTOS
  id_dentista Int
  dentista Dentista @relation(fields: [id_dentista], references: [id])
  imagem_postagem ImagemPostagem[]
  postagem_paciente PostagemPaciente[]

  @@index([tipo])
}

enum TipoPostagem {
  geral
  individual
}

model PostagemPaciente{
  // RELACIONAMENTOS
  id_postagem Int 
  postagem Postagem @relation(fields: [id_postagem], references: [id])
  id_paciente Int 
  paciente Paciente @relation(fields: [id_paciente], references: [id])
  @@id([id_paciente, id_postagem])
}

// CONVÊNIO

model Convenio{
  id Int @id @default(autoincrement())
  no_operadora String
  nu_carteirinha String
  dt_val_carteirinha DateTime

  // RELACIONAMENTOS
  id_paciente Int 
  paciente Paciente @relation(fields: [id_paciente], references: [id])
  consultas Consulta[]
}

// DOCUMENTO

model Documento{
  id Int @id @default(autoincrement())
  nome_doc String
  tipo_doc String
  extensao String
  tamanho_doc Float

  // RELACIONAMENTOS
  id_consulta Int 
  consulta Consulta @relation(fields: [id_consulta], references: [id])
}

