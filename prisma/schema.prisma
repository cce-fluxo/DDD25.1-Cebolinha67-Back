// SEÇÃO DE PESSOAS (DENTISTA, PACIENTE, USUÁRIO)

model usuario{
  id Int @id @default(autoincrement())
  no_usuario String
  email_usuario String @unique
  CPF String @unique
  NU_celular String @unique
  Genero String
  data_nascimento DateTime
  token_esqueci_senha String

  // RELACIONAMENTOS
  notificacao_usuario notificacao_usuario[]
  imagem_usuario imagem_usuario?
  
  paciente paciente?
  dentista dentista? 
  } 

model dentista{
  id Int @id @default(autoincrement())
  senha_dentista String
  formacao String
  Instituto String
  DataInicio DateTime
  DataTermino DateTime
  Especializacao String

  // RELACIONAMENTOS
  id_usuario Int @unique
  usuario usuario @relation(fields:[id_usuario], references: [id])
  postagen postagem[]
  endereco endereco?
  consultas consulta[]
}

model paciente{
  id Int @id @default(autoincrement())
  senha_paciente String
  RG String @unique

  // RELACIONAMENTOS
  id_usuario Int @unique
  usuario usuario @relation(fields:[id_usuario], references: [id])
  convenios convenio[]
  consultas consulta[]
}

// NOTIFICAÇÕES 

model notificacao{
  id Int @id @default(autoincrement())
  id_notificacao Int
  DS_mensagem String
  lido Boolean
  titulo String
  simbolo String

  // RELACIONAMENTOS
  notificacao_usuario notificacao_usuario?
}

model notificacao_usuario{
  id Int @id @default(autoincrement())

  // RELACIONAMENTOS
  id_notificacao Int @unique
  notificacao notificacao @relation(fields: [id_notificacao], references: [id])
  id_usuario Int @unique
  usuario usuario @relation(fields: [id_usuario], references: [id])
  id_consulta Int? @unique
  consulta consulta? @relation(fields: [id_consulta], references: [id])
}

// IMAGENS

model imagem{
  id Int @id @default(autoincrement())
  URL String
  Nome String

  // RELACIONAMENTOS
  imagem_usuario imagem_usuario[]
  imagem_postagem imagem_postagem[]
}

model imagem_usuario{
  id Int @id @default(autoincrement())

  // RELACIONAMENTOS
  id_imagem Int @unique
  imagem imagem @relation(fields: [id_imagem], references: [id])
  id_usuario Int @unique
  usuario usuario @relation(fields: [id_usuario], references: [id])
}

model imagem_postagem{
  id Int @id @default(autoincrement())

  // RELACIONAMENTOS
  id_imagem Int @unique
  imagem imagem @relation(fields: [id_imagem], references: [id])
  id_postagem Int @unique
  postagem postagem @relation(fields: [id_postagem], references: [id])
}

// ENDERECO

model endereco{
  id Int @id @default(autoincrement())
  data_criacao_endereco DateTime
  logradouro String
  cidade String
  estado String
  bairro String
  complemento String
  cep String

  // RELACIONAMENTOS
  id_dentista Int @unique
  dentista dentista @relation(fields: [id_dentista], references: [id])
  consultas consulta[]
}

// CONSULTA

model consulta {
  id Int @id @default(autoincrement())

  // RELACIONAMENTOS
  id_paciente Int @unique
  paciente paciente @relation(fields: [id_paciente], references: [id])
  id_dentista Int @unique
  dentista dentista @relation(fields: [id_dentista], references: [id])
  id_convenio Int @unique
  convenio convenio @relation(fields: [id_convenio], references: [id])
  id_endereco Int @unique
  endereco endereco @relation(fields: [id_endereco], references: [id])
  detalhe_da_consulta detalhe_da_consulta?
  documentos documento[]
  notificacao_usuario notificacao_usuario[]
}

model detalhe_da_consulta {
  id Int @id @default(autoincrement())
  DH DateTime
  valor Int
  tipo_pagamento tipo_pagamento @unique
  status String
  tipo_consulta String
  motivo String

  // RELACIONAMENTOS
  id_consulta Int @unique
  consulta consulta @relation(fields: [id_consulta], references: [id])
}

// tipo_pagamento é atributo (enumerado) da entidade detalhe_da_consulta
enum tipo_pagamento {
  Particular
  Convenio
}

// POSTAGEM

model postagem{
  id Int @id @default(autoincrement())
  id_postagem Int
  titulo String
  mensagem String
  tipo String
  data DateTime
  
  // RELACIONAMENTOS
  id_dentista Int @unique
  dentista dentista @relation(fields: [id_dentista], references: [id])
  imagem_postagem imagem_postagem[]
}

// CONVÊNIO

model convenio{
  id Int @id @default(autoincrement())
  id_convenio Int
  NO_operadora String
  NU_carteirinha String
  DT_val_carteirinha DateTime

  // RELACIONAMENTOS
  id_paciente Int @unique
  paciente paciente @relation(fields: [id_paciente], references: [id])
  consultas consulta[]
}

// DOCUMENTO

model documento{
  id Int @id @default(autoincrement())
  id_documento Int
  nome_doc String
  tipo_doc String
  extensao String
  tamanho_doc Float

  // RELACIONAMENTOS
  id_consulta Int @unique
  consulta consulta @relation(fields: [id_consulta], references: [id])
}


